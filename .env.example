MYSQL_DATABASE=speakloop
MYSQL_USER=speakloop_user
MYSQL_PASSWORD=speakloop_password
MYSQL_ROOT_PASSWORD=root_password

DATABASE_URL=mysql+pymysql://speakloop_user:speakloop_password@mysql:3306/speakloop?charset=utf8mb4
REDIS_URL=redis://redis:6379/0

BASE_URL=http://localhost:18000
CORS_ORIGINS=http://localhost:3000,http://localhost:13000
FRONTEND_PRIMARY_PORT=3000
BACKEND_PORT=18000
FRONTEND_PORT=13000
MYSQL_PORT=13306
REDIS_PORT=16379
UPLOAD_DIR=/data/uploads

JWT_SECRET=change-me
AUTO_CREATE_TABLES=true
SEED_DEFAULT_USERS=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
DEMO_USERNAME=user
DEMO_PASSWORD=user123456

MAX_VIDEO_SIZE_MB=2048
MAX_SUBTITLE_SIZE_MB=5
MAX_COVER_SIZE_MB=10

WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
